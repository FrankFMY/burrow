{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Burrow",
  "version": "0.5.0",
  "identifier": "com.frankfmy.burrow",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Burrow VPN",
        "width": 480,
        "height": 720,
        "minWidth": 380,
        "minHeight": 580,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Burrow VPN"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' http://127.0.0.1:9090; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "externalBin": ["binaries/burrow-vpn"]
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["burrow"]
      }
    },
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/burrow-vpn",
          "sidecar": true,
          "args": ["daemon"]
        }
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/FrankFMY/burrow/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
